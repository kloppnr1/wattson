# WattsOn Staging Environment — Template
# Copy this file to .env.staging and fill in real values before deploying.
# IMPORTANT: .env.staging is gitignored and must never be committed.

# Database
DB_USER=wattson
DB_PASSWORD=CHANGE_ME_use_a_real_password
DB_NAME=wattson

# App port (what colleagues hit in the browser)
APP_PORT=80
